# Configuración de conexión a PostgreSQL EXTERNO
# Configura estos valores según tu servidor PostgreSQL

# Servidor de base de datos (IP o dominio)
DB_HOST=tu_servidor_postgresql.com
DB_PORT=5432

# Credenciales de la base de datos
DB_NAME=tu_base_datos
DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña

# Configuración del dump (opcional)
DUMP_OUTPUT_DIR=./dumps
COMPRESS_DUMP=true
